# LLM models
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
SIGNAL_MODEL="gemini-2.5-flash"
REVIEW_MODEL="gemini-2.5-flash"
JUDGE_MODEL="gemini-2.5-flash"

# Binance environment
BINANCE_ENV="testnet"
BINANCE_SYMBOL="BTCUSDT"
BINANCE_SYMBOLS="BTCUSDT,ETHUSDT"
BINANCE_STREAM_INTERVAL="15m"
BINANCE_API_KEY="YOUR_BINANCE_API_KEY"
BINANCE_API_SECRET="YOUR_BINANCE_API_SECRET"
BINANCE_VALIDATE_ONLY="true"

# Currency choice:
# For execution quality, BTCUSDT is usually better because liquidity is much higher.
# If you want direct IDR trading, use BINANCE_SYMBOL="BTCIDR".
# If you want reporting in rupiah while still trading BTCUSDT, use REPORTING_CURRENCY="IDR" in backtests.

# Trading safety defaults
PAPER_TRADING="true"
PAPER_QUOTE_BALANCE="10000"
MAX_RISK_PER_TRADE_PCT="0.01"
MAX_POSITION_NOTIONAL="2000"
MIN_CONFIDENCE_THRESHOLD="0.70"
MAX_SIGNAL_AGE_SECONDS="1800"
MIN_ATR_FRACTION="0.002"
SIGNAL_MIN_BARS="120"
MAX_LIVE_SPREAD_BPS="12"
MIN_LIVE_DEPTH_NOTIONAL="100000"
SYMBOL_COOLDOWN_SECONDS="1800"
MAX_DAILY_LOSS_PCT="0.03"
MAX_DAILY_TRADES="8"

# Backtest realism
BACKTEST_FEE_BPS="10"
BACKTEST_LATENCY_BPS="2"
BACKTEST_SLIPPAGE_BUFFER_BPS="3"
BACKTEST_MIN_TRADE_COUNT="200"

# Scout agent
SCOUT_QUOTE_ASSET="USDT"
SCOUT_MAX_SYMBOLS="8"
SCOUT_MIN_QUOTE_VOLUME="50000000"
SCOUT_MAX_SPREAD_BPS="12"
SCOUT_INTERVAL_SECONDS="900"
