# LLM models
LLM_PROVIDER="openai"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_BASE_URL=""
SIGNAL_LLM_PROVIDER="openai"
REVIEW_LLM_PROVIDER="openai"
JUDGE_LLM_PROVIDER="openai"
SIGNAL_MODEL="gpt-5.4-mini"
REVIEW_MODEL="gpt-5.4-mini"
JUDGE_MODEL="gpt-5.4"

# Binance environment
BINANCE_ENV="testnet"
BINANCE_SYMBOL="BTCUSDT"
BINANCE_SYMBOLS="BTCUSDT,ETHUSDT"
BINANCE_STREAM_INTERVAL="15m"
HIGHER_TIMEFRAME_INTERVALS="30m,1h,4h,1d"
BINANCE_API_KEY="YOUR_BINANCE_API_KEY"
BINANCE_API_SECRET="YOUR_BINANCE_API_SECRET"
BINANCE_VALIDATE_ONLY="true"

# Internal services
POSTGRES_HOST="postgres"
POSTGRES_DB="trading_ledger"
POSTGRES_USER="trader"
POSTGRES_PASSWORD="securepassword"

# Currency choice:
# For execution quality, BTCUSDT is usually better because liquidity is much higher.
# If you want direct IDR trading, use BINANCE_SYMBOL="BTCIDR".
# If you want reporting in rupiah while still trading BTCUSDT, use REPORTING_CURRENCY="IDR" in backtests.

# Trading safety defaults
PAPER_TRADING="true"
PAPER_QUOTE_BALANCE="10000"
MAX_RISK_PER_TRADE_PCT="0.01"
MAX_POSITION_NOTIONAL="2000"
MIN_CONFIDENCE_THRESHOLD="0.70"
MAX_SIGNAL_AGE_SECONDS="1800"
MIN_ATR_FRACTION="0.002"
SIGNAL_MIN_BARS="220"
SIGNAL_PRELOAD_BARS="260"
MAX_LIVE_SPREAD_BPS="12"
MIN_LIVE_DEPTH_NOTIONAL="100000"
SYMBOL_COOLDOWN_SECONDS="1800"
MAX_DAILY_LOSS_PCT="0.03"
MAX_DAILY_TRADES="8"
HEARTBEAT_INTERVAL_SECONDS="30"
STALE_HEARTBEAT_SECONDS="120"
ALERT_MAX_FILL_SLIPPAGE_BPS="15"
KILL_SWITCH_REDIS_KEY="trading:kill_switch"
KILL_SWITCH_FILE="/tmp/trading.kill"

# Backtest realism
BACKTEST_FEE_BPS="10"
BACKTEST_LATENCY_BPS="2"
BACKTEST_SLIPPAGE_BUFFER_BPS="3"
BACKTEST_MIN_TRADE_COUNT="200"

# Scout agent
SCOUT_QUOTE_ASSET="USDT"
SCOUT_MAX_SYMBOLS="12"
SCOUT_SCAN_LIMIT="100"
SCOUT_MIN_QUOTE_VOLUME="50000000"
SCOUT_MIN_DEPTH_NOTIONAL="150000"
SCOUT_MAX_SPREAD_BPS="12"
SCOUT_MIN_CONFIDENCE="0.58"
SCOUT_LONG_ONLY="true"
SCOUT_PRIMARY_INTERVAL_BARS="260"
SCOUT_CONTEXT_INTERVALS="1h,4h"
SCOUT_INTERVAL_SECONDS="900"
